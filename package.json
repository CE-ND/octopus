{
  "name": "octopus-desktop",
  "version": "0.1.2",
  "private": true,
  "description": "Desktop wrapper for Octopus",
  "main": "desktop/main.js",
  "scripts": {
    "desktop:prepare": "node scripts/desktop-prepare.js",
    "desktop:dev": "pnpm desktop:prepare && electron .",
    "desktop:pack": "pnpm desktop:prepare && electron-builder --dir",
    "desktop:dist": "pnpm desktop:prepare && electron-builder",
    "desktop:dist:custom": "node scripts/desktop-custom-installer.js"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.hureru.octopus.desktop",
    "productName": "Octopus",
    "asar": true,
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/desktop/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "desktop/assets/icon.ico",
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Octopus"
    },
    "mac": {
      "identity": "-",
      "sign": "scripts/desktop-mac-sign.js",
      "hardenedRuntime": false,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "desktop/assets/icon.png",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "target": [
        "AppImage"
      ]
    }
  }
}
